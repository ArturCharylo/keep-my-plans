rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is in members
    function isMember(groupId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // Check if is owner
    function isCreator(groupId) {
      return isAuthenticated() &&
        request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
    }

    // User profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated(); 
      
      // Allow modyfications only by group members
      allow update: if isMember(groupId) || (
        request.auth.uid in request.resource.data.members && 
        request.resource.data.members.size() == resource.data.members.size() + 1
      );

      // Delete empty groups
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.createdBy || resource.data.members.size() == 0);

      match /items/{itemId} {
        allow read, create: if isMember(groupId);
        allow update: if isMember(groupId);
        // Usuwanie pozycji: Autor pozycji, Twórca grupy (przy usuwaniu całości) LUB jeśli grupa jest pusta
        allow delete: if isMember(groupId) && (
          resource.data.addedBy == request.auth.uid || 
          isCreator(groupId) ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.size() == 0
        );

        match /reactions/{userId} {
          allow read: if isMember(groupId);
          allow write: if isMember(groupId) && (
            request.auth.uid == userId || 
            isCreator(groupId) ||
            get(/databases/$(database)/documents/groups/$(groupId)).data.members.size() == 0
          );
        }
      }

      match /events/{eventId} {
        allow read, create: if isMember(groupId);
        allow update: if isMember(groupId) && resource.data.addedBy == request.auth.uid;
        allow delete: if isMember(groupId) && (
          resource.data.addedBy == request.auth.uid || 
          isCreator(groupId) ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.members.size() == 0
        );
      }
    }
  }
}